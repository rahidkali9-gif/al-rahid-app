# ─────────────────────────────────────────────────────────────
# Al Rahid Backend — Environment Variables Example
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=Al Rahid
APP_URL=http://localhost:3000

# JWT
JWT_SECRET=change-me-to-a-long-random-string-please
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# API Keys (issued to users)
API_KEY_PREFIX=arh_live_

# CORS
CORS_ORIGIN=*

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alrahid
DB_USER=alrahid
DB_PASSWORD=alrahid_secret
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# ── AI Providers ─────────────────────────────────────────────
# Active provider: openai | openrouter | groq | ollama
AI_PROVIDER=openai
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-openai-key
AI_DEFAULT_MODEL=gpt-4o-mini
AI_IMAGE_MODEL=dall-e-3
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# OpenRouter
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Groq
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# Ollama (local)
OLLAMA_API_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_DEFAULT_MODEL=llama3.1

# ── AI Feature Costs (credits charged per generation) ────────
AI_CHAT_COST=10
AI_IMAGE_COST=50
AI_VIDEO_COST=200
AI_VOICE_COST=80
AI_MUSIC_COST=120
AI_LOGO_COST=60
AI_RESUME_COST=40
AI_PRESENTATION_COST=90
AI_PDF_SUMMARY_COST=30
AI_CODE_COST=20
AI_WEBSITE_COST=100
AI_APP_COST=150
AI_EMAIL_COST=15
AI_DOCUMENT_COST=25

# ── Default Admin (used by seed) ─────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@alrahid.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_DEMO_EMAIL=demo@alrahid.com
DEFAULT_DEMO_PASSWORD=Demo@123456
