{
  "name": "alrahid-backend",
  "version": "1.0.0",
  "description": "Al Rahid — production-ready Node.js/Express/PostgreSQL backend with AI features, wallet, admin panel, and RBAC.",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "migrate": "node scripts/migrate.js",
    "migrate:undo": "node scripts/migrate.js --undo",
    "seed": "node scripts/seed.js",
    "db:reset": "node scripts/migrate.js && node scripts/seed.js",
    "zip": "node scripts/zip.js"
  },
  "keywords": [
    "express",
    "postgresql",
    "jwt",
    "ai",
    "backend"
  ],
  "author": "Al Rahid",
  "license": "MIT",
  "dependencies": {
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "winston": "^3.13.0"
  }
}
