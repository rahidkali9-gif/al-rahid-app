<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- ===== Auth ===== -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.alrahid.app.ui.auth.LoginFragment"
        android:label="@string/action_login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.alrahid.app.ui.auth.RegisterFragment"
        android:label="@string/action_register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ===== Dashboard ===== -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.alrahid.app.ui.dashboard.DashboardFragment"
        android:label="@string/nav_dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <!-- ===== AI ===== -->
    <fragment
        android:id="@+id/aiChatFragment"
        android:name="com.alrahid.app.ui.ai.AiChatFragment"
        android:label="@string/ai_chat"
        tools:layout="@layout/fragment_ai_chat" />

    <fragment
        android:id="@+id/aiGeneratorFragment"
        android:name="com.alrahid.app.ui.ai.AiGeneratorFragment"
        android:label="@string/ai_image"
        tools:layout="@layout/fragment_ai_generator">
        <argument
            android:name="type"
            app:argType="string"
            android:defaultValue="image" />
    </fragment>

    <fragment
        android:id="@+id/aiPdfSummaryFragment"
        android:name="com.alrahid.app.ui.ai.AiPdfSummaryFragment"
        android:label="@string/ai_pdf"
        tools:layout="@layout/fragment_ai_pdf_summary" />

    <fragment
        android:id="@+id/aiGenerationsFragment"
        android:name="com.alrahid.app.ui.ai.AiGenerationsFragment"
        android:label="@string/ai_history"
        tools:layout="@layout/fragment_ai_generations" />

    <!-- ===== Profile / Settings / Wallet / Notifications / History ===== -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.alrahid.app.ui.profile.ProfileFragment"
        android:label="@string/nav_profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.alrahid.app.ui.settings.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/walletFragment"
        android:name="com.alrahid.app.ui.wallet.WalletFragment"
        android:label="@string/nav_wallet"
        tools:layout="@layout/fragment_wallet" />

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.alrahid.app.ui.notifications.NotificationsFragment"
        android:label="@string/nav_notifications"
        tools:layout="@layout/fragment_notifications" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.alrahid.app.ui.history.HistoryFragment"
        android:label="@string/nav_history"
        tools:layout="@layout/fragment_history" />

</navigation>
